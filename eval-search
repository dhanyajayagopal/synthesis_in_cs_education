#!/usr/bin/env python3

from node import *

import sys
import json

def bool_to_js(b):
    if not isinstance(b, bool):
        raise TypeError("Output of 'search' must be a boolean.")

    if b:
        return "true"
    else:
        return "false"

try:
    body = json.loads(sys.stdin.read())

    exec(body["code"]) # defines 'search'

    sys.stderr.write(str(body["testInputs"][0]) + "\n")

    outputs = [
        bool_to_js(search(node_from_js(ti[0]), int(ti[1])))
        for ti in body["testInputs"]
    ]

    print("[" + ",".join(outputs) + "]")

except SyntaxError as e:
    print("Syntax error:", e, end="")

except TypeError as e:
    print("Type error:", e, end="")
