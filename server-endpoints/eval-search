#!/usr/bin/env python3

from node import *

import sys
import json

def bool_to_js(b):
    if not isinstance(b, bool):
        raise TypeError("Output of 'search' must be a boolean.")

    if b:
        return "true"
    else:
        return "false"

try:
    body = json.loads(sys.stdin.read())

    exec(body["code"]) # defines 'search'

    outputs = [
        bool_to_js(search(node_from_js(ti[0]), int(ti[1])))
        for ti in body["testInputs"]
    ]

    print('{ "code": 0, "outputs": [' + ','.join(outputs) + '], "kind": "code" }')

except Exception as e:
    print('{ "code": 1, "error": ' + json.dumps(str(e)) + '}')
