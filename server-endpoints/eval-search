#!/usr/bin/env python3

import runner
from node import *

def bool_to_js(b):
    if not isinstance(b, bool):
        raise TypeError("Output of 'search' must be a boolean.")

    if b:
        return "true"
    else:
        return "false"

def run_function(testInput, search):
    return bool_to_js(search(node_from_js(testInput[0]), int(testInput[1])))

runner.run(run_function, "search", "code")
