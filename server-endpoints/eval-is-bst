#!/usr/bin/env python3

from runner import *
from node import *

def bool_to_js(b):
    if not isinstance(b, bool):
        raise TypeError("Output of 'isBST' must be a boolean.")

    if b:
        return "true"
    else:
        return "false"

def run_function(testInput, insert):
    return node_to_js(isBST(node_from_js(testInput[0])))

run(run_function, "insert", "tree")
